# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_ADMIN_KEY=

# SERP
SERP_PROVIDER=serpapi
SERP_API_KEY=
SERP_BASE_URL=https://serpapi.com/search
SERP_NEWS=true

# EDINET
EDINET_API_KEY=
EDINET_SUBSCRIPTION_KEY=
EDINET_BASE_URL=https://api.edinet-fsa.go.jp/api/v2
EDINET_LOOKBACK_DAYS=1200
EDINET_DOC_TYPE=2
EDINET_REQUIRE_XBRL=true
EDINET_PREFERRED_DOCTYPES=120,130,140,160,110
EDINET_ONLY=false
EDINET_INSTANCE_TRY_LIMIT=6

# J-Quants
JQUANTS_API_KEY=
JQUANTS_BASE_URL=https://api.jpx-jquants.com
JQUANTS_MODE=api_key
JQUANTS_REFRESH_TOKEN=
JQUANTS_API_KEY_HEADER=X-API-KEY
JQUANTS_FINANCIALS_ENDPOINT=/v1/fins/statements
JQUANTS_PRICES_ENDPOINT=/v1/prices/daily_quotes
JQUANTS_COMPANY_ENDPOINT=/v1/listed/info

# Report
REPORT_OUTPUT=pdf
OUTPUT_DIR=output
MAX_SOURCES=8
MOCK_MODE=false
USAGE_LOOKBACK_DAYS=30

# ML Valuation
ML_ENABLED=true
ML_MAX_TICKERS=200
ML_CACHE_DAYS=7
ML_MIN_SAMPLES=30

# DCF
DCF_WACC=0.08
DCF_TERMINAL_GROWTH=0.015
DCF_YEARS=5
